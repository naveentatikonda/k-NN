diff --git a/src/main/java/org/opensearch/knn/memoryoptsearch/faiss/vectorvalues/FaissFloatVectorValues.java b/src/main/java/org/opensearch/knn/memoryoptsearch/faiss/vectorvalues/FaissFloatVectorValues.java
