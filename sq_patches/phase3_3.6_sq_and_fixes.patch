+    private static FaissScorableByteVectorValues createWrapper() {
+        return new FaissScorableByteVectorValues(
+            new PreDefinedByteVectorValues(VECTORS),
+            mock(FlatVectorsScorer.class),
+            VectorSimilarityFunction.EUCLIDEAN,
+            null
+        );
+    }
